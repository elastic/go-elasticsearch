{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "go",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "include-v-in-release-name": false,
  "versioning": "always-bump-patch",
  "bootstrap-sha": "c0ce8353ed3d8023cd7f2a02970e82296f20fa46",
  "last-release-sha": "c0ce8353ed3d8023cd7f2a02970e82296f20fa46",
  "draft-pull-request": true,
  "extra-label": "apidiff: release",
  "always-update": true,
  "packages": {
    ".": {
      "version-file": "internal/version/version.go"
    }
  },
  "plugins": [
    {
      "type": "sentence-case"
    }
  ]
}
